# Qwen3-ASR-Serve runtime configuration.
# Copy to .env or set as real env vars.

# ─── Serving mode ─────────────────────────────────────────────────────────
# asr     — only ASR loaded. Routes: /v1/audio/transcriptions[/batch].
#           Timestamp requests will 400.
# aligner — only ForcedAligner loaded. Routes: /v1/audio/forced_alignment[/batch].
# both    — both loaded (default). All routes available. Aligner shared with ASR.
MODE=both

# ─── Models ───────────────────────────────────────────────────────────────
MODEL_DIR=./models
ASR_MODEL_PATH=./models/Qwen3-ASR-1.7B
ALIGNER_MODEL_PATH=./models/Qwen3-ForcedAligner-0.6B
# HF endpoint for model download (set to https://hf-mirror.com if HF unreachable)
HF_ENDPOINT=

# ─── Performance ──────────────────────────────────────────────────────────
# vLLM gpu_memory_utilization. Recommended:
#   MODE=asr     → 0.85  (no aligner contention)
#   MODE=both    → 0.6   (leave room for aligner KV)
#   MODE=aligner → ignored (transformers backend)
GPU_MEM_UTIL=0.6

# vLLM ASR python-side chunk size. Sweet spot 256–512 on L20 (PERF_1.7B.md).
ASR_BATCH=256

# Aligner internal batch (independent of ASR_BATCH). Sweet spot is 16 — gives
# +6.4% throughput and 4.4× memory reduction vs aligning at the same batch
# as ASR. See perf_bench/test_split_aligner_batch.py.
ALIGNER_BATCH=16

# ─── HTTP server ──────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── File-path input (performance feature) ────────────────────────────────
# When true, callers may pass file_path / file_paths[] to skip multipart upload.
# DANGER: enables arbitrary local file reads — set ALLOWED_PATH_PREFIXES to lock
# the readable area down.
ALLOW_LOCAL_PATHS=false
# Comma-separated absolute prefixes. Every supplied path is resolved with
# os.path.realpath() and must start with one of these. Empty list → reject all.
ALLOWED_PATH_PREFIXES=

# Upload size cap (multipart only). Default 200 MiB.
MAX_FILE_BYTES=209715200

# ─── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=info
